{
  "name": "images",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/images",
  "tags": ["type:images", "stack:docker"],
  "targets": {
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/images",
        "command": "docker build -t churrostack/{args.image}:latest ./{args.image}"
      }
    }
  }
}
